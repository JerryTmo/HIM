<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.layout.Region?>

<AnchorPane prefWidth="1300" prefHeight="700" style="-fx-background-color: #f0f2f5;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.controller.HomeController">

    <VBox spacing="0" AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.bottomAnchor="0">

        <!-- 顶部导航栏 -->
        <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #1e88e5; -fx-padding: 12 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10, 0, 0, 3);">

            <HBox spacing="10" alignment="CENTER_LEFT">
                <StackPane prefHeight="45" prefWidth="45" style="-fx-background-color: white; -fx-background-radius: 12;">
                    <Label text="🏥" style="-fx-font-size: 28;" />
                </StackPane>
                <VBox spacing="0">
                    <Label text="医院医疗管理系统" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: white;" />
                    <Label text="Hospital Management System" style="-fx-font-size: 11; -fx-text-fill: #e3f2fd;" />
                </VBox>
            </HBox>

            <Region HBox.hgrow="ALWAYS" />

            <HBox spacing="12" alignment="CENTER_RIGHT">
                <StackPane>
                    <Circle radius="22" style="-fx-fill: white;" />
                    <Label text="👤" style="-fx-font-size: 22;" />
                </StackPane>
                <VBox spacing="2">
                    <Label text="欢迎，" style="-fx-font-size: 13; -fx-text-fill: #e3f2fd;" />
                    <Label fx:id="usernameLabel" text="用户" style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: white;" />
                </VBox>
                <Button text="退出" onAction="#handleLogout" style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-background-radius: 6; -fx-font-size: 13; -fx-cursor: hand;" />
            </HBox>
        </HBox>

        <!-- 主体区域 -->
        <HBox spacing="15" style="-fx-padding: 20;" VBox.vgrow="ALWAYS">

            <!-- 左侧动态菜单栏 -->
            <VBox spacing="15" prefWidth="260" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 3);">

                <Label text="📋 功能菜单" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #666;" />

                <ScrollPane fx:id="menuScrollPane" fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-color: transparent;">
                    <VBox fx:id="menuContainer" spacing="5" />
                </ScrollPane>

                <!-- 快捷功能区域（可选的动态快捷入口） -->
                <VBox fx:id="shortcutContainer" spacing="8" style="-fx-background-color: #fff3e0; -fx-background-radius: 10; -fx-padding: 15;" managed="false" visible="false">
                    <Label text="⚡ 快捷功能" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #e65100;" />
                </VBox>
            </VBox>

            <!-- 右侧动态内容区域 -->
            <VBox spacing="15" HBox.hgrow="ALWAYS">

                <StackPane fx:id="contentArea" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 3);">
                    <!-- 默认首页欢迎内容 -->
                    <VBox spacing="20" alignment="TOP_CENTER" style="-fx-padding: 40;">
                        <Label text="🏠" style="-fx-font-size: 48;" />
                        <Label text="欢迎使用医院医疗管理系统" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #333;" />
                        <Label text="请从左侧菜单选择功能模块" style="-fx-font-size: 14; -fx-text-fill: #999;" />
                    </VBox>
                </StackPane>
            </VBox>
        </HBox>

        <!-- 底部状态栏 -->
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: white; -fx-padding: 10 25; -fx-border-color: #eee; -fx-border-width: 1 0 0 0;">
            <Label text="📍 医院医疗管理系统" style="-fx-font-size: 12; -fx-text-fill: #666;" />
            <Region HBox.hgrow="ALWAYS" />
            <Label text="© 2025 医院医疗管理系统" style="-fx-font-size: 11; -fx-text-fill: #999;" />
        </HBox>
    </VBox>
</AnchorPane>
