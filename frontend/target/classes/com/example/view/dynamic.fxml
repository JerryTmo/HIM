<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.shape.Circle?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.controller.FeedController">
    
    <!-- 動態頁面標題 -->
    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 0 10 0;">
        <Label text="📱 最新動態" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #333;" />
        <Region HBox.hgrow="ALWAYS" />
        <Button text="🔄 刷新" onAction="#handleRefresh" style="-fx-background-color: #f0f0f0; -fx-text-fill: #666; -fx-background-radius: 15; -fx-padding: 5 15;" />
    </HBox>
    
    <!-- 動態列表（使用 ScrollPane 支持滾動） -->
    <ScrollPane fitToWidth="true" prefWidth="260"  style="-fx-background-color: transparent; -fx-border: none; -fx-background-insets: 0; -fx-padding: 0;" VBox.vgrow="ALWAYS" hbarPolicy="NEVER" 
            vbarPolicy="NEVER">
        <VBox fx:id="feedContainer" spacing="15" style="-fx-background-color: transparent; -fx-padding: 0 0 20 0;">
            
            <!-- 動態項目 1 -->
            <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.03), 5, 0, 0, 2);">
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Circle radius="20" style="-fx-fill: linear-gradient(from 0% 0% to 100% 100%, #6B73FF 0%, #000DFF 100%);" />
                    <VBox spacing="2">
                        <Label text="李明" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #333;" />
                        <Label text="2小時前" style="-fx-font-size: 11; -fx-text-fill: #999;" />
                    </VBox>
                </HBox>
                <Label text="今天學習了JavaFX，感覺很強大！準備做一個AI思維導圖工具。" style="-fx-font-size: 13; -fx-text-fill: #666; -fx-padding: 10 0 10 0;" wrapText="true" />
                <HBox spacing="20" alignment="CENTER">
                    <Button text="👍 12" onAction="#handleLike" style="-fx-background-color: transparent; -fx-text-fill: #666; -fx-font-size: 12;" />
                    <Button text="💬 3" onAction="#handleComment" style="-fx-background-color: transparent; -fx-text-fill: #666; -fx-font-size: 12;" />
                    <Button text="↗️ 分享" onAction="#handleShare" style="-fx-background-color: transparent; -fx-text-fill: #666; -fx-font-size: 12;" />
                </HBox>
            </VBox>
            
            <!-- 動態項目 2 -->
            <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.03), 5, 0, 0, 2);">
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Circle radius="20" style="-fx-fill: linear-gradient(from 0% 0% to 100% 100%, #FF6B6B 0%, #FF0000 100%);" />
                    <VBox spacing="2">
                        <Label text="王芳" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #333;" />
                        <Label text="昨天" style="-fx-font-size: 11; -fx-text-fill: #999;" />
                    </VBox>
                </HBox>
                <Label text="分享一個AI生成的思維導圖，關於項目管理的核心知識點，非常實用！" style="-fx-font-size: 13; -fx-text-fill: #666; -fx-padding: 10 0 10 0;" wrapText="true" />
                <HBox spacing="20" alignment="CENTER">
                    <Button text="👍 8" onAction="#handleLike" style="-fx-background-color: transparent; -fx-text-fill: #666; -fx-font-size: 12;" />
                    <Button text="💬 2" onAction="#handleComment" style="-fx-background-color: transparent; -fx-text-fill: #666; -fx-font-size: 12;" />
                    <Button text="↗️ 分享" onAction="#handleShare" style="-fx-background-color: transparent; -fx-text-fill: #666; -fx-font-size: 12;" />
                </HBox>
            </VBox>
            
            <!-- 動態項目 3 -->
            <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.03), 5, 0, 0, 2);">
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Circle radius="20" style="-fx-fill: linear-gradient(from 0% 0% to 100% 100%, #4ECDC4 0%, #2C9A8E 100%);" />
                    <VBox spacing="2">
                        <Label text="張偉" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #333;" />
                        <Label text="3天前" style="-fx-font-size: 11; -fx-text-fill: #999;" />
                    </VBox>
                </HBox>
                <Label text="新功能上線！現在可以用AI一鍵生成思維導圖，輸入主題即可，大家快來試試～" style="-fx-font-size: 13; -fx-text-fill: #666; -fx-padding: 10 0 10 0;" wrapText="true" />
                <HBox spacing="20" alignment="CENTER">
                    <Button text="👍 24" onAction="#handleLike" style="-fx-background-color: transparent; -fx-text-fill: #666; -fx-font-size: 12;" />
                    <Button text="💬 7" onAction="#handleComment" style="-fx-background-color: transparent; -fx-text-fill: #666; -fx-font-size: 12;" />
                    <Button text="↗️ 分享" onAction="#handleShare" style="-fx-background-color: transparent; -fx-text-fill: #666; -fx-font-size: 12;" />
                </HBox>
            </VBox>
            
        </VBox>
    </ScrollPane>
</VBox>