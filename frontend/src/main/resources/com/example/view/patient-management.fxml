<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.Separator?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.Region?>

<AnchorPane prefWidth="1200" prefHeight="650" style="-fx-background-color: #f0f2f5;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.controller.PatientManagementController">
    
    <VBox spacing="15" AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.bottomAnchor="0" style="-fx-padding: 20;">
        
        <HBox spacing="15" alignment="CENTER_LEFT">
            <Button text="← 返回首页" onAction="#handleBack" style="-fx-background-color: #e0e0e0; -fx-text-fill: #333; -fx-background-radius: 8; -fx-cursor: hand;" />
            <Label text="🏥 患者管理" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #333;" />
            <Region HBox.hgrow="ALWAYS" />
            <TextField fx:id="searchField" promptText="搜索患者姓名或电话..." style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 8 15; -fx-pref-width: 250;" />
            <Button text="🔍 搜索" onAction="#handleSearch" style="-fx-background-color: #1e88e5; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 8 20; -fx-cursor: hand;" />
        </HBox>
        
        <HBox spacing="15" VBox.vgrow="ALWAYS">
            
            <VBox spacing="15" prefWidth="400" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20;">
                <Label text="📝 患者信息" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #333;" />
                <Separator />
                
                <TextField fx:id="nameField" promptText="患者姓名" style="-fx-background-color: #f5f5f5; -fx-background-radius: 8; -fx-padding: 10;" />
                <HBox spacing="10">
                    <ComboBox fx:id="genderComboBox" promptText="性别" style="-fx-background-color: #f5f5f5; -fx-background-radius: 8; -fx-padding: 10;" HBox.hgrow="ALWAYS" />
                    <TextField fx:id="ageField" promptText="年龄" style="-fx-background-color: #f5f5f5; -fx-background-radius: 8; -fx-padding: 10;" HBox.hgrow="ALWAYS" />
                </HBox>
                <TextField fx:id="phoneField" promptText="联系电话" style="-fx-background-color: #f5f5f5; -fx-background-radius: 8; -fx-padding: 10;" />
                <TextField fx:id="idCardField" promptText="身份证号" style="-fx-background-color: #f5f5f5; -fx-background-radius: 8; -fx-padding: 10;" />
                <TextField fx:id="addressField" promptText="家庭住址" style="-fx-background-color: #f5f5f5; -fx-background-radius: 8; -fx-padding: 10;" />
                
                <Region VBox.vgrow="ALWAYS" />
                
                <HBox spacing="10">
                    <Button fx:id="addButton" text="➕ 添加患者" onAction="#handleAddPatient" style="-fx-background-color: #43a047; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 12 20; -fx-cursor: hand;" HBox.hgrow="ALWAYS" />
                    <Button fx:id="updateButton" text="✏️ 修改" onAction="#handleUpdatePatient" style="-fx-background-color: #fb8c00; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 12 20; -fx-cursor: hand;" HBox.hgrow="ALWAYS" />
                    <Button fx:id="deleteButton" text="🗑️ 删除" onAction="#handleDeletePatient" style="-fx-background-color: #e53935; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 12 20; -fx-cursor: hand;" HBox.hgrow="ALWAYS" />
                </HBox>
            </VBox>
            
            <VBox spacing="10" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20;">
                <Label text="📋 患者列表" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #333;" />
                <Separator />
                
                <TableView fx:id="patientTable" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="idColumn" text="患者ID" prefWidth="100" />
                        <TableColumn fx:id="nameColumn" text="姓名" prefWidth="100" />
                        <TableColumn fx:id="genderColumn" text="性别" prefWidth="60" />
                        <TableColumn fx:id="ageColumn" text="年龄" prefWidth="60" />
                        <TableColumn fx:id="phoneColumn" text="电话" prefWidth="130" />
                        <TableColumn fx:id="statusColumn" text="状态" prefWidth="80" />
                    </columns>
                </TableView>
            </VBox>
        </HBox>
    </VBox>
</AnchorPane>
