<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.shape.Circle?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.Region?>

<AnchorPane prefWidth="1300" prefHeight="700" style="-fx-background-color: #f0f2f5;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.controller.HomeController">
    
    <VBox spacing="0" AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.bottomAnchor="0">
        
        <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #1e88e5; -fx-padding: 12 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10, 0, 0, 3);">
            
            <HBox spacing="10" alignment="CENTER_LEFT">
                <StackPane prefHeight="45" prefWidth="45" style="-fx-background-color: white; -fx-background-radius: 12;">
                    <Label text="🏥" style="-fx-font-size: 28;" />
                </StackPane>
                <VBox spacing="0">
                    <Label text="医院医疗管理系统" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: white;" />
                    <Label text="Hospital Management System" style="-fx-font-size: 11; -fx-text-fill: #e3f2fd;" />
                </VBox>
            </HBox>
            
            <Region HBox.hgrow="ALWAYS" />
            
            <HBox spacing="12" alignment="CENTER_RIGHT">
                <StackPane>
                    <Circle radius="22" style="-fx-fill: white;" />
                    <Label text="👤" style="-fx-font-size: 22;" />
                </StackPane>
                <VBox spacing="2">
                    <Label text="欢迎，" style="-fx-font-size: 13; -fx-text-fill: #e3f2fd;" />
                    <Label fx:id="usernameLabel" text="管理员" style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: white;" />
                </VBox>
                <Button text="退出" onAction="#handleLogout" style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-background-radius: 6; -fx-font-size: 13; -fx-cursor: hand;" />
            </HBox>
        </HBox>
        
        <HBox spacing="15" style="-fx-padding: 20;" VBox.vgrow="ALWAYS">
            
            <VBox spacing="15" prefWidth="260" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 3);">
                
                <Label text="📋 主要功能" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #666;" />
                
                <VBox spacing="8">
                    <Button text="🏥 患者管理" onAction="#handlePatientManagement" style="-fx-background-color: #e3f2fd; -fx-text-fill: #1976d2; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 12 18; -fx-font-size: 14; -fx-cursor: hand; -fx-font-weight: 500;" />
                    <Button text="👨‍⚕️ 医生排班" onAction="#handleDoctorSchedule" style="-fx-background-color: #f5f5f5; -fx-text-fill: #666; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 12 18; -fx-font-size: 14; -fx-cursor: hand;" />
                    <Button text="📝 病历管理" onAction="#handleMedicalRecord" style="-fx-background-color: #f5f5f5; -fx-text-fill: #666; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 12 18; -fx-font-size: 14; -fx-cursor: hand;" />
                    <Button text="💊 药品管理" onAction="#handleMedicineManagement" style="-fx-background-color: #f5f5f5; -fx-text-fill: #666; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 12 18; -fx-font-size: 14; -fx-cursor: hand;" />
                    <Button text="📅 预约管理" onAction="#handleAppointmentManagement" style="-fx-background-color: #f5f5f5; -fx-text-fill: #666; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 12 18; -fx-font-size: 14; -fx-cursor: hand;" />
                </VBox>
                
                <Separator />
                
                <VBox spacing="10" style="-fx-background-color: #fff3e0; -fx-background-radius: 10; -fx-padding: 15;">
                    <Label text="📊 系统概览" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #e65100;" />
                    <GridPane hgap="20" vgap="10">
                        <Label text="今日患者" style="-fx-font-size: 12; -fx-text-fill: #666;" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <Label text="28" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #1976d2;" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        <Label text="今日预约" style="-fx-font-size: 12; -fx-text-fill: #666;" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <Label text="15" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #43a047;" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                    </GridPane>
                </VBox>
                
                <Region VBox.vgrow="ALWAYS" />
                
                <VBox spacing="10">
                    <Label text="⚙️ 系统设置" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #666;" />
                    <Button text="系统设置" onAction="#handleSettings" style="-fx-background-color: transparent; -fx-text-fill: #666; -fx-alignment: CENTER_LEFT; -fx-font-size: 13; -fx-cursor: hand;" />
                </VBox>
            </VBox>
            
            <VBox spacing="15" HBox.hgrow="ALWAYS">
                
                <Label text="🏠 系统首页" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #333;" />
                
                <GridPane hgap="15" vgap="15" HBox.hgrow="ALWAYS">
                    <VBox spacing="10" style="-fx-background-color: linear-gradient(to right, #1e88e5, #42a5f5); -fx-background-radius: 12; -fx-padding: 20;" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <Label text="👥" style="-fx-font-size: 32;" />
                        <Label text="患者总数" style="-fx-font-size: 14; -fx-text-fill: rgba(255,255,255,0.9);" />
                        <Label text="1,248" style="-fx-font-size: 32; -fx-font-weight: bold; -fx-text-fill: white;" />
                    </VBox>
                    
                    <VBox spacing="10" style="-fx-background-color: linear-gradient(to right, #43a047, #66bb6a); -fx-background-radius: 12; -fx-padding: 20;" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <Label text="👨‍⚕️" style="-fx-font-size: 32;" />
                        <Label text="医生总数" style="-fx-font-size: 14; -fx-text-fill: rgba(255,255,255,0.9);" />
                        <Label text="86" style="-fx-font-size: 32; -fx-font-weight: bold; -fx-text-fill: white;" />
                    </VBox>
                    
                    <VBox spacing="10" style="-fx-background-color: linear-gradient(to right, #fb8c00, #ffa726); -fx-background-radius: 12; -fx-padding: 20;" GridPane.columnIndex="2" GridPane.rowIndex="0">
                        <Label text="📋" style="-fx-font-size: 32;" />
                        <Label text="今日预约" style="-fx-font-size: 14; -fx-text-fill: rgba(255,255,255,0.9);" />
                        <Label text="42" style="-fx-font-size: 32; -fx-font-weight: bold; -fx-text-fill: white;" />
                    </VBox>
                    
                    <VBox spacing="10" style="-fx-background-color: linear-gradient(to right, #e53935, #ef5350); -fx-background-radius: 12; -fx-padding: 20;" GridPane.columnIndex="3" GridPane.rowIndex="0">
                        <Label text="💊" style="-fx-font-size: 32;" />
                        <Label text="药品库存" style="-fx-font-size: 14; -fx-text-fill: rgba(255,255,255,0.9);" />
                        <Label text="3,456" style="-fx-font-size: 32; -fx-font-weight: bold; -fx-text-fill: white;" />
                    </VBox>
                </GridPane>
                
                <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 3);" VBox.vgrow="ALWAYS">
                    <Label text="📢 系统通知" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #333;" />
                    <Separator />
                    <VBox spacing="10">
                        <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-background-color: #f5f5f5; -fx-background-radius: 8; -fx-padding: 12;">
                            <Label text="📌" style="-fx-font-size: 18;" />
                            <VBox spacing="2">
                                <Label text="系统升级通知" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #333;" />
                                <Label text="系统将于本周六凌晨 2:00 进行升级维护" style="-fx-font-size: 12; -fx-text-fill: #666;" />
                            </VBox>
                        </HBox>
                        <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-background-color: #e8f5e9; -fx-background-radius: 8; -fx-padding: 12;">
                            <Label text="✅" style="-fx-font-size: 18;" />
                            <VBox spacing="2">
                                <Label text="新功能上线" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #2e7d32;" />
                                <Label text="电子病历签名功能已上线" style="-fx-font-size: 12; -fx-text-fill: #666;" />
                            </VBox>
                        </HBox>
                    </VBox>
                </VBox>
            </VBox>
        </HBox>
        
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: white; -fx-padding: 10 25; -fx-border-color: #eee; -fx-border-width: 1 0 0 0;">
            <Label text="📍 当前时间: 2025-01-15 14:30" style="-fx-font-size: 12; -fx-text-fill: #666;" />
            <Region HBox.hgrow="ALWAYS" />
            <Label text="© 2025 医院医疗管理系统" style="-fx-font-size: 11; -fx-text-fill: #999;" />
        </HBox>
    </VBox>
</AnchorPane>
