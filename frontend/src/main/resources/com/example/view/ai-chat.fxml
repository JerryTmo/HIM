<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.controller.AIChatController"
            style="-fx-background-color: #f5f6fa;">

    <VBox spacing="0" AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <!-- 顶部标题栏 -->
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 5, 0, 0, 2);">
            <padding>
                <Insets top="15" right="25" bottom="15" left="25"/>
            </padding>
            <Label text="🤖" style="-fx-font-size: 28px;"/>
            <VBox>
                <Label text="医小助" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2d3436;"/>
                <Label text="AI 医疗智能助手" style="-fx-font-size: 12px; -fx-text-fill: #b2bec3;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="newChatBtn" text="➕ 新对话" onAction="#handleNewChat"
                    style="-fx-background-color: #6c5ce7; -fx-text-fill: white; -fx-background-radius: 20; -fx-cursor: hand; -fx-padding: 8 18;"/>
        </HBox>

        <!-- 消息区域 -->
        <ScrollPane fx:id="messageScrollPane" VBox.vgrow="ALWAYS"
                    style="-fx-background: transparent; -fx-background-color: transparent; -fx-border: none;">
            <VBox fx:id="messageContainer" spacing="15"
                  style="-fx-padding: 20 25; -fx-background-color: #f5f6fa;">
                <!-- 消息由 JavaFX Controller 动态填充 -->
            </VBox>
        </ScrollPane>

        <!-- 底部输入栏 -->
        <VBox spacing="8"
              style="-fx-background-color: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 5, 0, 0, -2);">
            <padding>
                <Insets bottom="15" left="20" right="20" top="12"/>
            </padding>

            <!-- 快捷提示 -->
            <HBox fx:id="suggestionBar" spacing="8" alignment="CENTER_LEFT">
                <Label text="💡 快捷提问:" style="-fx-font-size: 11px; -fx-text-fill: #b2bec3; -fx-font-weight: bold;"/>
                <Button text="咳嗽发烧怎么办" onAction="#handleSuggestion" userData="咳嗽发烧怎么办"
                        style="-fx-background-color: #dfe6e9; -fx-text-fill: #636e72; -fx-background-radius: 15; -fx-cursor: hand; -fx-font-size: 11; -fx-padding: 4 12;"/>
                <Button text="头痛是什么原因" onAction="#handleSuggestion" userData="头痛是什么原因"
                        style="-fx-background-color: #dfe6e9; -fx-text-fill: #636e72; -fx-background-radius: 15; -fx-cursor: hand; -fx-font-size: 11; -fx-padding: 4 12;"/>
                <Button text="应该看什么科" onAction="#handleSuggestion" userData="应该看什么科"
                        style="-fx-background-color: #dfe6e9; -fx-text-fill: #636e72; -fx-background-radius: 15; -fx-cursor: hand; -fx-font-size: 11; -fx-padding: 4 12;"/>
            </HBox>

            <!-- 输入框 + 发送按钮 -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="inputField" HBox.hgrow="ALWAYS" promptText="输入您的医疗问题..."
                           style="-fx-background-color: #f5f6fa; -fx-background-radius: 22; -fx-border-radius: 22; -fx-border-color: #dfe6e9; -fx-padding: 10 18; -fx-font-size: 14px;"/>
                <Button fx:id="sendBtn" text="发送" onAction="#handleSend"
                        style="-fx-background-color: #6c5ce7; -fx-text-fill: white; -fx-background-radius: 22; -fx-cursor: hand; -fx-padding: 10 24; -fx-font-weight: bold; -fx-font-size: 14px;"/>
            </HBox>
        </VBox>
    </VBox>
</AnchorPane>
